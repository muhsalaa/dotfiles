theme = tokyonight
background-opacity = 0.95
background-blur-radius = 20
keybind = ctrl+h=goto_split:previous
keybind = ctrl+l=goto_split:next
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+right_bracket=next_tab
keybind = ctrl+left_bracket=previous_tab
keybind = ctrl+shift+right_bracket=move_tab:+1
keybind = ctrl+shift+left_bracket=move_tab:-1
